{
  "info": {
    "name": "ReqRes QA Collection",
    "_postman_id": "reqres-qa-advanced",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. USERS - Functional Tests",
      "item": [
        {
          "name": "GET Users List",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              }
            ],
            "url": "{{base_url}}/api/users?page=2"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has data array', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET Single User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              }
            ],
            "url": "{{base_url}}/api/users/2"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('User ID is 2', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data.id).to.eql(2);",
                  "});",
                  "",
                  "pm.test('Email exists', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data.email).to.not.be.null;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "CREATE User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{$randomFirstName}}\",\n  \"job\": \"qa tester\"\n}"
            },
            "url": "{{base_url}}/api/users"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201 or 200', () => {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "pm.test('Response has id', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('id');",
                  "});",
                  "",
                  "pm.test('Response contains name & job', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.name).to.exist;",
                  "    pm.expect(json.job).to.eql('qa tester');",
                  "});"
                ]
              }
            }
          ]
        },
        {
  "name": "UPDATE User (PATCH)",
  "request": {
    "method": "PATCH",
    "header": [
      {
        "key": "Content-Type",
        "value": "application/json"
      },
      {
        "key": "x-api-key",
        "value": "{{api_key}}"
      }
    ],
    "body": {
      "mode": "raw",
      "raw": "{\n  \"name\": \"{{$randomFirstName}}\",\n  \"job\": \"senior qa engineer\"\n}"
    },
    "url": "{{base_url}}/api/users/2"
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "exec": [
          "pm.test('Status is 200 or 204', () => {",
          "    pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
          "});",
          "",
          "pm.test('Response validation safe check', () => {",
          "    if (pm.response.text()) {",
          "        const json = pm.response.json();",
          "        pm.expect(json).to.be.an('object');",
          "    }",
          "});",
          "",
          "pm.test('Updated job is correct', () => {",
          "    if (pm.response.text()) {",
          "        const json = pm.response.json();",
          "        pm.expect(json.job).to.eql('senior qa engineer');",
          "    }",
          "});"
        ]
      }
    }
  ]
},
        {
          "name": "DELETE User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              }
            ],
            "url": "{{base_url}}/api/users/2"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 204', () => {",
                  "    pm.response.to.have.status(204);",
                  "});",
                  "",
                  "pm.test('Response body is empty', () => {",
                  "    pm.expect(pm.response.text()).to.eql('');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. AUTH - Negative Tests",
      "item": [
        {
          "name": "Login Missing Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"peter@klaven\"\n}"
            },
            "url": "{{base_url}}/api/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400', () => {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Error exists', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('error');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Invalid Email Format",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"invalid-email\",\n  \"password\": \"123\"\n}"
            },
            "url": "{{base_url}}/api/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400', () => {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Error returned', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('error');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Invalid User ID Format",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              }
            ],
            "url": "{{base_url}}/api/users/abc"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 404', () => {",
                  "    pm.expect(pm.response.code).to.eql(404);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "3. BOUNDARY TESTS",
      "item": [
        {
          "name": "Empty Payload Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": "{{base_url}}/api/users"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('API handles safely', () => {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201, 400, 422]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Wrong Data Types",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": 12345,\n  \"job\": true\n}"
            },
            "url": "{{base_url}}/api/users"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('API handles invalid types safely', () => {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201, 400, 422]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Large Input Values",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa\",\n  \"job\": \"bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb\"\n}"
            },
            "url": "{{base_url}}/api/users"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('API does not crash', () => {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201, 400, 422, 413]);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}